MAILER_PORT=3005

# Fallback SMTP global (opcional).
# Default recomendado: false
# Cuando está en false, el servicio exige configuración SMTP activa por cliente.
SMTP_FALLBACK_ENABLED=false

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Base de datos (obligatorio: auditoría + lookup SMTP por cliente)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# ==========================
# Leadmaster Central Hub
# ==========================

# Entorno
NODE_ENV=development
PORT=3012

# Seguridad (JWT)
# Usado para firmar/verificar tokens en authService
SESSION_SECRET=change_me

# Base de datos (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=leadmaster_dev
DB_PORT=3306

# Scheduler de campañas automáticas
AUTO_CAMPAIGNS_ENABLED=false

# Integración: Session Manager
SESSION_MANAGER_BASE_URL=http://localhost:3001

# Listener
INTERNAL_LISTENER_TOKEN=change_me
LISTENER_MODE=listen
OPENAI_API_KEY=

# Integración: Mailer (leadmaster-mailer)
MAILER_BASE_URL=http://localhost:3005
MAILER_TIMEOUT_MS=10000
